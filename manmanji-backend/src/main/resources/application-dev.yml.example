# ==========================================
# 开发环境敏感配置模板
# 复制为 application-dev.yml 后填入真实值：
#   cp application-dev.yml.example application-dev.yml
# ==========================================

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/manmanji
    username: postgres
    password: your-password

  data:
    redis:
      host: localhost
      port: 6379

  ai:
    openai:
      api-key: ${DEEPSEEK_API_KEY:sk-placeholder}

# AI 厂商 API Key（去对应平台申请）
AI_BAILIAN_API_KEY: your-bailian-key-here       # https://bailian.console.aliyun.com/
PROVIDER_KIMI_API_KEY: ""                        # https://platform.moonshot.cn/
PROVIDER_DEEPSEEK_API_KEY: ""                    # https://platform.deepseek.com/
PROVIDER_GLM_API_KEY: ""                         # https://open.bigmodel.cn/

# 配置加密密钥（用于加密存储 API Key 到数据库）
APP_AI_CONFIG_ENCRYPTION_KEY: ""
